# Which config/*.json to load (see lib/config.ts) — "testnet" | "local"
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Base URL of the AquaSwap indexer REST API (see indexer/src/api/server.ts).
# Port is whatever PORT the indexer was started with — 4000 is just its default,
# pick a free port on your machine (this repo's testnet indexer runs on 4100).
NEXT_PUBLIC_INDEXER_URL=http://localhost:4000
